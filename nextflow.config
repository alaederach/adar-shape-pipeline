// ═══════════════════════════════════════════════════════════════════════════
// adar-shape-pipeline configuration
// ═══════════════════════════════════════════════════════════════════════════

manifest {
    name            = 'adar-shape-pipeline'
    description     = 'ShapeMapper + ADAR (A->G) read sorting / deconvolution / normalization'
    author          = 'Alain Laederach'
    homePage        = 'https://github.com/alaederach/adar-shape-pipeline'
    mainScript      = 'main.nf'
    version         = '0.1.0'
    // main.nf / step02.nf use language constructs removed by NF 26's strict parser;
    // fail fast with a clear message if run on an unsupported Nextflow.
    nextflowVersion = '>=25.04.0, <25.10.0'
}

params {
    samplesheet = "${projectDir}/input/samplesheet.csv"
    outdir      = "${projectDir}/results"

    // ShapeMapper 2.2 executable (x86-64 Linux only).
    //   - native Linux : leave as 'shapemapper' (must be on PATH), or an absolute path
    //                    (or set env ADAR_SHAPEMAPPER_BIN)
    //   - other hosts  : use `-profile docker` (wraps the container; see README)
    shapemapper_bin = System.getenv('ADAR_SHAPEMAPPER_BIN') ?: 'shapemapper'

    // `slurm` profile only: shell run before each task (e.g. to activate a conda env
    // providing samtools/pysam/python). Set for your install, or via env
    // ADAR_CLUSTER_BEFORE_SCRIPT. ShapeMapper is self-contained and ignores it.
    cluster_before_script = System.getenv('ADAR_CLUSTER_BEFORE_SCRIPT') ?: ''

    // ShapeMapper run parameters
    min_mutation_separation = 0       // 0 keeps every A→G mismatch (the ADAR editing signal)
    min_depth               = 5000
    random_primer_len       = 9       // used only for random-primed libraries

    // Mutation signature tracked for editing (ADAR = A->G). Used by the edit-position
    // ranking helper and step-02 read sorting.
    refbase  = 'A'
    readbase = 'G'

    // ── STEP 02 (read sorting) ────────────────────────────────────────────────
    // Path to step01's results/ dir. REQUIRED when running step02 (step02.nf
    // resolves the ADAR aligned SAMs + ADAR-DMSO profile from here by convention).
    step01_outdir = null

    step02 {
        // Read-count floor for the edited-set threshold selection: the sorter picks
        // the HIGHEST "n-of-N edited" threshold where both BAMs still have at least
        // this many reads. This MUST be >= min_depth (5000): the deconvolution step
        // re-runs ShapeMapper on the sorted reads, whose HQ/normalized profile masks
        // every position below min_depth. A lower floor here lets the sorter pick a
        // stringent threshold that yields too few reads, leaving the normalized
        // profile all-nan. Keep these two coupled (raise both together for deeper data).
        edited_min_depth       = 5000
        unedited_min_depth     = 5000
        min_coverage_percent   = 75
        unedited_max_tolerance = 10
        no_unedited            = true   // skip the unedited (AA) read sets by default
    }
}

process {
    cpus   = 4
    memory = '8 GB'

    withName: 'SHAPEMAPPER' {
        cpus   = 12
        memory = '8 GB'
    }
}

profiles {
    // Default: native ShapeMapper on the local machine.
    standard {
    }

    // Run ShapeMapper through the container wrapper (for macOS / non-Linux hosts).
    docker {
        params.shapemapper_bin = "${projectDir}/bin/shapemapper-docker"
        // Cap requests to a typical laptop — the SHAPEMAPPER request of 12 cpus would
        // exceed a 10-core machine and the local executor would refuse to schedule it.
        process.resourceLimits = [ cpus: 10, memory: '48 GB' ]
    }

    // Generic SLURM cluster: native ShapeMapper on x86 nodes, one job per sample.
    // Install-specific settings are parameterized — set them for your account:
    //   --shapemapper_bin /path/to/shapemapper   (or env ADAR_SHAPEMAPPER_BIN)
    //   --cluster_before_script '...'             (or env ADAR_CLUSTER_BEFORE_SCRIPT)
    // The before-script activates an env providing samtools/pysam/python for the
    // non-ShapeMapper steps (SAM_TO_BAM / QUERY_SORTED_BAM / REVERT_SNV / RANK_POSITIONS).
    // Example (e.g. a SLURM cluster with a conda install):
    //   ADAR_SHAPEMAPPER_BIN=/path/to/shapemapper-2.2/shapemapper
    //   ADAR_CLUSTER_BEFORE_SCRIPT='source ~/miniforge3/etc/profile.d/conda.sh && conda activate shape-adar'
    slurm {
        process {
            executor      = 'slurm'
            queue         = 'general'      // override per cluster as needed
            time          = '4h'
            beforeScript  = params.cluster_before_script
            // ShapeMapper streams reads through FIFOs + many small temp files —
            // pathologically slow on networked filesystems. Run ONLY ShapeMapper in
            // node-local scratch ($TMPDIR); other steps do plain large-file I/O.
            scratch       = { task.process == 'SHAPEMAPPER' }
            // squeue polling can transiently lose a running job, making Nextflow falsely
            // declare it "terminated by external system" — retry rather than abort.
            errorStrategy = 'retry'
            maxRetries    = 2
        }
        executor {
            queueSize         = 16
            submitRateLimit   = '10/1min'
            pollInterval      = '30 sec'
            queueStatInterval = '2 min'
            exitReadTimeout   = '60 min'   // tolerate slow jobs / squeue-poll gaps
        }
    }
}
